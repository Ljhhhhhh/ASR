{
  "name": "asr",
  "version": "1.0.0",
  "description": "An Electron application with React and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "asr:runtime:prepare:mac": "node scripts/prepare_asr_runtime.mjs --platform darwin-arm64",
    "asr:runtime:prepare:mac-arm64": "node scripts/prepare_asr_runtime.mjs --platform darwin-arm64",
    "asr:runtime:prepare:windows": "node scripts/prepare_asr_runtime.mjs --platform win32-x64",
    "asr:runtime:prepare:win-x64": "node scripts/prepare_asr_runtime.mjs --platform win32-x64",
    "asr:runtime:verify": "node scripts/verify_asr_runtime.mjs",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac:local": "npm run asr:runtime:prepare:mac && npm run asr:runtime:verify && electron-vite build && electron-builder --mac --arm64 --config electron-builder.local.yml",
    "build:win:local": "npm run asr:runtime:prepare:windows && npm run asr:runtime:verify && electron-vite build && electron-builder --win --x64 --config electron-builder.local.yml",
    "build:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@langchain/core": "^1.2.0",
    "@langchain/openai": "^1.5.1",
    "@langchain/textsplitters": "^1.0.1",
    "langchain": "^1.5.0",
    "markdown-to-image": "^0.0.13",
    "mermaid": "^11.15.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
